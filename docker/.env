# ============================================================
#  Environment Configuration — Apache Kafka Course
#  Edit this file to tune memory, versions, and credentials
# ============================================================

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_VERSION=4.0.0

# Must be a valid 22-character base64 UUID.
# Do NOT change this after first run (volumes will mismatch).
# Generate a new one: python -c "import uuid,base64; print(base64.urlsafe_b64encode(uuid.uuid4().bytes).decode().rstrip('='))"
CLUSTER_ID=4L6g3lTnSsmthwI408djhg

# Memory — lower if your laptop has less than 8GB RAM
KAFKA_HEAP=512m
KAFKA_HEAP_MIN=256m

# Log retention (hours)
LOG_RETENTION_HOURS=168

# ── Kafdrop ───────────────────────────────────────────────────
KAFDROP_VERSION=latest
KAFDROP_PORT=9000

# ── Kafka Connect ─────────────────────────────────────────────
CONNECT_HEAP=512m

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_VERSION=8.0
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=kafka_course
MYSQL_USER=kafka
MYSQL_PASSWORD=kafka123

# ── Elasticsearch ─────────────────────────────────────────────
ES_VERSION=8.11.4
# Lower to 256m if laptop has less than 8GB RAM
ES_HEAP=512m