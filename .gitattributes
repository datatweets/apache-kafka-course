# Ensure shell scripts and config files always use LF line endings
# (prevents "bad interpreter" errors when Windows users clone the repo)
*.sh        text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.py        text eol=lf
*.env       text eol=lf
*.sql       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.properties text eol=lf
